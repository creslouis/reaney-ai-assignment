# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# AI
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com

# Security
ADMIN_API_KEY=your_secret_admin_key_here
SURVEY_WEBHOOK_TOKEN=your_secret_google_form_token

# App
FRONTEND_URL=https://your-app.vercel.app
ENVIRONMENT=development

# ML Settings
ML_RETRAIN_THRESHOLD=50
ML_RETRAIN_INTERVAL_DAYS=7

# Optional: Google Sheets
GOOGLE_SHEETS_API_KEY=optional_for_bulk_import

# Auth / CMS
JWT_SECRET_KEY=change_me_to_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_ALLOWED_ADMIN_EMAILS=admin@example.com
JWT_REFRESH_SECRET_KEY=change_me_to_a_second_long_random_secret
