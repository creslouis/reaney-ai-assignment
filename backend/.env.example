# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Use the "Session mode" URL (port 5432) for direct connections
# OR use "Transaction mode" URL (port 6543) for Render's pooled connections
# asyncpg format: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com

# ─── Security ──────────────────────────────────────────────────────────────────
ADMIN_API_KEY=your_secret_admin_key_here
SURVEY_WEBHOOK_TOKEN=your_secret_google_form_token

# ─── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
ENVIRONMENT=development

# ─── ML Settings ───────────────────────────────────────────────────────────────
ML_RETRAIN_THRESHOLD=50
ML_RETRAIN_INTERVAL_DAYS=7

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET_KEY=change_me_to_a_second_long_random_secret

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Comma-separated list of Google emails that get role="admin" on first login
GOOGLE_ALLOWED_ADMIN_EMAILS=admin@example.com

# ─── Optional: Google Sheets ───────────────────────────────────────────────────
GOOGLE_SHEETS_API_KEY=optional_for_bulk_import
