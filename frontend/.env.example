# ─── API Base URL ──────────────────────────────────────────────────────────────
# Your Render backend URL (no trailing slash)
VITE_API_BASE_URL=https://career-finder-api.onrender.com

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Same Client ID as backend - from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
